# Server Configuration
PORT=5000
NODE_ENV=development

# Groq API Configuration
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1

# Cartesia API Configuration
# Get your API key from: https://cartesia.ai/
CARTESIA_API_KEY=sk_car_mSkCdtu5jxjCEMigcNYvNP

# ElevenLabs API Configuration
# Get your API key from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_preferred_voice_id_here
# Popular voice IDs:
# - 21m00Tcm4TlvDq8ikWAM (Rachel - calm)
# - EXAVITQu4vr4xnSDxMaL (Bella - soft)
# - ErXwobaYiN019PkySvjV (Antoni - well-rounded)

# Audio Configuration
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SIZE=4096

# LLM Configuration
# Available Groq models:
# - llama-3.1-70b-versatile (recommended for conversation)
# - llama-3.1-8b-instant (fastest)
# - mixtral-8x7b-32768 (large context)
# - gemma2-9b-it
LLM_MODEL=llama-3.1-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=150
STREAM_ENABLED=true

# Default Provider Settings
DEFAULT_LLM_MODEL=llama-3.3-70b-versatile
DEFAULT_STT_MODEL=whisper-large-v3
DEFAULT_TTS_PROVIDER=cartesia
DEFAULT_TTS_MODEL=sonic-english

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_PAYLOAD=10485760

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/voice-ai-platform

# Logging
LOG_LEVEL=info


